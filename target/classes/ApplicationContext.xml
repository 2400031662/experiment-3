<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-3.1.xsd
           http://www.springframework.org/schema/context
           http://www.springframework.org/schema/context/spring-context-3.1.xsd">
           

<context:annotation-config />

<bean id="a1" class="com.klu.springdi.Address">
	<constructor-arg value="hostel1"></constructor-arg>
	<constructor-arg value="100" type="int"></constructor-arg>
</bean>    
 <bean id="a2" class="com.klu.springdi.Address">
	<constructor-arg value="hostel2"></constructor-arg>
	<constructor-arg value="101" type="int"></constructor-arg>
</bean> 
<bean id="s1" class="com.klu.springdi.Student">
	<property name="id" value="1"></property>
	<property name="name" value="s1name"></property>
	<!-- <property name="address" ref="a1"></property>-->
</bean>
</beans>